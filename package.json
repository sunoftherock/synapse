{
  "name": "synapse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A personal connected-brain notetaker: notes, meetings, Jira pastes, and an auto-linking mind map.",
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"node --watch server/index.js\" \"vite\"",
    "seed": "node server/seed.js",
    "build": "vite build",
    "start": "node server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": ">=0.88 <2",
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/view": "^6.34.0",
    "@uiw/react-codemirror": "^4.23.0",
    "express": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.27.0",
    "react-markdown": "^10.0.0",
    "react-router-dom": "^7.1.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0"
  }
}
